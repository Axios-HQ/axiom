# Copy to .env.local and fill in values

# Control plane URL (deployed or local wrangler dev)
CONTROL_PLANE_URL=https://your-control-plane.workers.dev

# Session to attach to (create one via web UI first)
SESSION_ID=

# Sandbox credentials (from session init response)
SANDBOX_ID=
SANDBOX_AUTH_TOKEN=

# GitHub token for the agent
GITHUB_TOKEN=
