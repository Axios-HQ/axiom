{
  "name": "@open-inspect/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --platform=browser --target=es2022 --external:cloudflare:* --external:node:* --external:@cloudflare/containers --alias:path=node:path",
    "backfill:identity-links": "node ./backfill-identity-links.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.1",
    "@cloudflare/workers-types": "^4.20241230.0",
    "@open-inspect/shared": "file:../shared",
    "agents": "^0.7.5",
    "ai": "^6.0.116"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.10",
    "@vitest/coverage-v8": "^3.2.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0",
    "wrangler": "^4.0.0"
  }
}
